{
  "name": "octosarmy",
  "author": "nRn World",
  "description": "Multi-Agent Control System för AI-driven filhantering",
  "private": false,
  "version": "1.1.26",
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:electron": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --outfile=dist/server.js && electron .",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --external:vite --external:electron --outfile=dist/server.js",
    "dist": "vite build && npm run build:server && electron-builder --win",
    "clean": "rm -rf dist release"
  },
  "build": {
    "appId": "com.nRnWorld.octosarmy",
    "productName": "OctosArmy",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "Logo/OSAI-no-bg.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "shortcutName": "OctosArmy",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "nRn-World",
        "repo": "octosarmy"
      }
    ],
    "files": [
      "dist/**/*",
      "electron-main.js",
      "preload.js",
      "Logo/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/server.js",
        "to": "server.js"
      },
      {
        "from": "preload.js",
        "to": "preload.js"
      },
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*",
          "!server.js"
        ]
      },
      ".env"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/node-cron": "^3.0.11",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cron": "^4.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
