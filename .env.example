# --- OctoSync AI (Python + Ollama, local engine) ---
# Sandbox: only this directory is used by `python -m octosync`
SANDBOX_ROOT="D:\\APPS By nRn World\\Windows\\OctoSync AI\\workspace"
# Ollama API (default port 11434)
OLLAMA_BASE_URL="http://localhost:11434"
# Model tag as in `ollama list` (e.g. gemma3:4b — use the exact name you pulled)
OLLAMA_MODEL="gemma3:4b"
# Optional: force Ollama in the browser even if a Gemini key exists
# VITE_USE_OLLAMA=true
# If the UI is not served from the same host:port as Express (3000), set e.g.:
# VITE_API_BASE_URL=http://localhost:3000
# Optional: max agent steps, terminal timeout (seconds), max terminal output (characters)
# OCTOSYNC_MAX_STEPS=24
# OCTOSYNC_TERMINAL_TIMEOUT=120
# OCTOSYNC_MAX_TERMINAL_OUTPUT=50000
# Future: Node/Vite (server.ts) may call `python -m octosync ...` or a small HTTP wrapper.

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
